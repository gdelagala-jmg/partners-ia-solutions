generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Sector {
  id          String     @id @default(uuid())
  name        String
  slug        String     @unique
  image       String
  externalUrl String
  description String?    @db.Text
  order       Int        @default(0)
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  solutions   Solution[] @relation("SectorToSolution")
}

model Solution {
  id                    String          @id @default(uuid())
  type                  String          @default("SOLUTION")
  title                 String
  slug                  String          @unique
  description           String          @db.Text
  longDescription       String?         @db.Text
  multimedia            String?
  ctaUrl                String?
  tags                  String?
  order                 Int             @default(0)
  published             Boolean         @default(false)
  featured              Boolean         @default(false)
  featuredOrder         Int?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  functionalDescription String?         @db.Text
  problemsSolved        String?         @db.Text
  capabilities          String?         @db.Text
  workflowDescription   String?         @db.Text
  gallery               SolutionMedia[]
  sectors               Sector[]        @relation("SectorToSolution")
}

model SolutionMedia {
  id         String   @id @default(uuid())
  solutionId String
  url        String
  alt        String?
  type       String   @default("IMAGE")
  order      Int      @default(0)
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  solution   Solution @relation(fields: [solutionId], references: [id], onDelete: Cascade)

  @@index([solutionId], map: "SolutionMedia_solutionId_fkey")
}

model NewsPost {
  id              String    @id @default(uuid())
  title           String
  slug            String    @unique
  category        String
  aiType          String?
  businessArea    String?
  sector          String?
  profession      String?
  coverImage      String?   @db.Text
  content         String    @db.LongText
  published       Boolean   @default(false)
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  tags            String?
  aiTool          String?
  company         String?
  podcastAudioUrl String?   @db.Text
  gmbErrorMessage String?   @db.Text
  gmbLastSync     DateTime?
  gmbSyncStatus   String    @default("PENDING")
}

model TeamMember {
  id           String   @id @default(uuid())
  name         String
  role         String?
  bio          String?  @db.Text
  photoUrl     String?
  socialLinks  String   @default("{}")
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  customFields String   @default("{}")
  linkedIn     String?
  phone        String?
  showName     Boolean  @default(true)
  showPhoto    Boolean  @default(true)
}

model SuccessCase {
  id           String   @id @default(uuid())
  partnerName  String
  logoUrl      String?
  description  String   @db.Text
  referenceUrl String?
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model MediaItem {
  id        String   @id @default(uuid())
  type      String   @default("VIDEO")
  title     String
  url       String?
  embedHtml String?  @db.Text
  thumbnail String?
  published Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteSetting {
  key   String @id
  value String @db.Text
}

model Partner {
  id          String   @id @default(uuid())
  name        String
  logoUrl     String?
  description String?  @db.Text
  websiteUrl  String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Lead {
  id            String   @id @default(uuid())
  name          String
  email         String
  phone         String?
  message       String   @db.Text
  status        String   @default("NEW")
  createdAt     DateTime @default(now())
  bottleneck    String?
  desiredResult String?
  scope         String?
  source        String   @default("CONTACT")
  urgency       Int?
  company       String?
  solutionSlug  String?
  solutionTitle String?
  solutionType  String?
  sourcePage    String?
  sourceUrl     String?
}

model AdminUser {
  id              String          @id @default(uuid())
  username        String          @unique
  passwordHash    String
  createdAt       DateTime        @default(now())
  dashboardConfig String?         @db.LongText
  authenticators  Authenticator[]
}

model Authenticator {
  id                   String    @id @default(uuid())
  credentialID         String    @unique
  credentialPublicKey  String    @db.VarChar(1024)
  counter              BigInt    @default(0)
  credentialDeviceType String
  credentialBackedUp   Boolean   @default(false)
  transports           String?
  name                 String
  createdAt            DateTime  @default(now())
  lastUsedAt           DateTime?
  adminUserId          String
  adminUser            AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
}

model Course {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  description String   @db.Text
  level       String
  duration    String
  price       String?
  coverImage  String?
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model IADailyNews {
  id          String   @id @default(uuid())
  title       String
  url         String   @unique
  source      String
  publishedAt DateTime
  summary     String?  @db.Text
  createdAt   DateTime @default(now())
}

model Client {
  id           String   @id @default(uuid())
  companyName  String
  taxId        String?
  address      String?
  website      String?
  sector       String?
  contactName  String?
  contactPhone String?
  logoUrl      String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model NavLink {
  id        String   @id @default(uuid())
  name      String
  href      String
  location  String   @default("HEADER")
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AssistantLead {
  id          String   @id @default(uuid())
  name        String
  email       String
  phone       String?
  company     String?
  chatSummary String?  @db.Text
  status      String   @default("NEW")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  insights    String?  @db.Text
  priority    String?  @default("MEDIUM")
  sentiment   String?  @default("NEUTRAL")
}

model Application {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?  @db.Text
  image       String?
  externalUrl String?  @db.Text
  content     String?  @db.LongText
  published   Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ConsentLog {
  id         String   @id @default(uuid())
  email      String
  action     String
  acceptedAt DateTime @default(now())
  ipAddress  String?
  userAgent  String?
}

model PodcastEpisode {
  id          String   @id @default(uuid())
  title       String
  description String   @db.Text
  audioUrl    String   @db.Text
  duration    Int?
  fileSize    Int?
  pubDate     DateTime @default(now())
  guid        String   @unique @default(uuid())
  coverImage  String?  @db.Text
  link        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model NewsletterSubscriber {
  id               String                  @id @default(uuid())
  email            String                  @unique
  isActive         Boolean                 @default(true)
  sourceLocation   String?
  sourceUrl        String?
  consentAccepted  Boolean                 @default(true)
  consentAt        DateTime                @default(now())
  unsubscribeToken String                  @unique @default(uuid())
  confirmedAt      DateTime?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  logs             NewsletterCampaignLog[]
}

model NewsletterCampaign {
  id                   String                  @id @default(uuid())
  title                String
  subject              String
  preheader            String?
  introText            String?                 @db.LongText
  heroImage            String?                 @db.Text
  primaryCtaText       String?
  primaryCtaUrl        String?
  status               String                  @default("DRAFT")
  scheduledFor         DateTime?
  sentAt               DateTime?
  autoGenerated        Boolean                 @default(false)
  sourcePostId         String?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  content              String?                 @db.LongText
  recommendedSolutions String?                 @db.LongText
  showInterests        Boolean                 @default(true)
  logs                 NewsletterCampaignLog[]
}

model NewsletterCampaignLog {
  id             String               @id @default(uuid())
  campaignId     String
  subscriberId   String
  deliveryStatus String               @default("PENDING")
  provider       String?
  providerMsgId  String?
  openedAt       DateTime?
  clickedAt      DateTime?
  createdAt      DateTime             @default(now())
  lastError      String?              @db.Text
  campaign       NewsletterCampaign   @relation(fields: [campaignId], references: [id])
  subscriber     NewsletterSubscriber @relation(fields: [subscriberId], references: [id])

  @@unique([campaignId, subscriberId])
  @@index([subscriberId], map: "NewsletterCampaignLog_subscriberId_fkey")
}

model NewsletterSetting {
  id                      String  @id @default("GLOBAL")
  autoSendEnabled         Boolean @default(false)
  autoSendDelayMinutes    Int     @default(15)
  senderName              String?
  senderEmail             String?
  brandingLogo            String?
  footerText              String? @db.Text
  defaultCrossSellEnabled Boolean @default(true)
  doubleOptInEnabled      Boolean @default(false)
}

model StrategicPartner {
  id              String   @id @default(uuid())
  name            String
  slug            String   @unique
  logoUrl         String?
  logoAlt         String?
  websiteUrl      String?
  category        String?  @default("Strategic")
  displayOrder    Int      @default(0)
  isActive        Boolean  @default(true)
  isFeatured      Boolean  @default(false)
  showInFooter    Boolean  @default(true)
  showInHomepage  Boolean  @default(false)
  showInSolutions Boolean  @default(false)
  brandColor      String?
  logoVariant     String?  @default("ORIGINAL")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("strategic_partners")
}

model SitePartnerSettings {
  id              String   @id @default("GLOBAL")
  sectionTitle    String   @default("Partners Estratégicos")
  sectionSubtitle String?  @default("")
  layoutType      String   @default("horizontal-logos")
  maxVisibleItems Int      @default(8)
  autoplay        Boolean  @default(false)
  animationSpeed  Int      @default(3000)
  showDividers    Boolean  @default(true)
  showBackground  Boolean  @default(false)
  backgroundStyle String   @default("minimal")
  mobileStack     Boolean  @default(true)
  footerEnabled   Boolean  @default(true)
  updatedAt       DateTime @updatedAt

  @@map("site_partner_settings")
}
model EditorialContent {
  id              String    @id @default(uuid())
  pageKey         String    // e.g. "home", "soluciones"
  sectionKey      String    // e.g. "hero", "footer-cta"
  badge           String?
  titleLine1      String?
  titleLine2      String?
  subtitle        String?   @db.Text
  supportText     String?   @db.Text
  ctaText         String?
  ctaUrl          String?
  category        String?   @default("GENERAL")
  tone            String?   @default("DIRECT")
  isActive        Boolean   @default(true)
  priority        Int       @default(0)
  startDate       DateTime?
  endDate         DateTime?
  internalNotes   String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([pageKey, sectionKey, isActive, priority])
  @@map("editorial_contents")
}
