generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Sector {
  id          String     @id @default(uuid())
  name        String
  slug        String     @unique
  image       String
  externalUrl String
  description String?    @db.Text
  order       Int        @default(0)
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  solutions   Solution[] @relation("SectorToSolution")
}

model Solution {
  id              String   @id @default(uuid())
  type            String   @default("SOLUTION")
  title           String
  slug            String   @unique
  description     String   @db.Text
  longDescription String?  @db.Text
  multimedia      String?
  ctaUrl          String?
  tags            String?
  order           Int      @default(0)
  published       Boolean  @default(false)
  featured        Boolean  @default(false)
  featuredOrder   Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  sectors         Sector[] @relation("SectorToSolution")
}

model NewsPost {
  id              String    @id @default(uuid())
  title           String
  slug            String    @unique
  category        String
  aiType          String?
  businessArea    String?
  sector          String?
  profession      String?
  coverImage      String?   @db.Text
  content         String    @db.LongText
  published       Boolean   @default(false)
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  tags            String?
  aiTool          String?
  company         String?
  podcastAudioUrl String?   @db.Text
}

model TeamMember {
  id           String   @id @default(uuid())
  name         String
  role         String?
  bio          String?  @db.Text
  photoUrl     String?
  socialLinks  String   @default("{}")
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  customFields String   @default("{}")
  linkedIn     String?
  phone        String?
  showName     Boolean  @default(true)
  showPhoto    Boolean  @default(true)
}

model SuccessCase {
  id           String   @id @default(uuid())
  partnerName  String
  logoUrl      String?
  description  String   @db.Text
  referenceUrl String?
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model MediaItem {
  id        String   @id @default(uuid())
  type      String   @default("VIDEO")
  title     String
  url       String?
  embedHtml String?  @db.Text
  thumbnail String?
  published Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteSetting {
  key   String @id
  value String @db.Text
}

model Partner {
  id          String   @id @default(uuid())
  name        String
  logoUrl     String?
  description String?  @db.Text
  websiteUrl  String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Lead {
  id            String   @id @default(uuid())
  name          String
  email         String
  phone         String?
  message       String   @db.Text
  status        String   @default("NEW")
  createdAt     DateTime @default(now())
  bottleneck    String?
  desiredResult String?
  scope         String?
  source        String   @default("CONTACT")
  urgency       Int?
}

model AdminUser {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Course {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  description String   @db.Text
  level       String
  duration    String
  price       String?
  coverImage  String?
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model IADailyNews {
  id          String   @id @default(uuid())
  title       String
  url         String   @unique
  source      String
  publishedAt DateTime
  summary     String?  @db.Text
  createdAt   DateTime @default(now())
}

model Client {
  id           String   @id @default(uuid())
  companyName  String
  taxId        String?
  address      String?
  website      String?
  sector       String?
  contactName  String?
  contactPhone String?
  logoUrl      String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model NavLink {
  id        String   @id @default(uuid())
  name      String
  href      String
  location  String   @default("HEADER")
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AssistantLead {
  id          String   @id @default(uuid())
  name        String
  email       String
  phone       String?
  company     String?
  chatSummary String?  @db.Text
  status      String   @default("NEW")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Application {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?  @db.Text
  image       String?
  externalUrl String?  @db.Text
  content     String?  @db.LongText
  published   Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ConsentLog {
  id         String   @id @default(uuid())
  email      String
  action     String
  acceptedAt DateTime @default(now())
  ipAddress  String?
  userAgent  String?
}

model PodcastEpisode {
  id          String   @id @default(uuid())
  title       String
  description String   @db.Text
  audioUrl    String   @db.Text
  duration    Int?
  fileSize    Int?
  pubDate     DateTime @default(now())
  guid        String   @unique @default(uuid())
  coverImage  String?  @db.Text
  link        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
